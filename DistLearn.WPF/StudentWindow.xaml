<Window x:Class="DistLearn.WPF.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кабінет студента"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="Кабінет студента"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock x:Name="UserText"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <Button x:Name="ExitBtn"
                        Content="Вийти"
                        Width="100"
                        Height="38"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#374151"
                        Click="ExitBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,0,12,0">

                <StackPanel>
                    <TextBlock Text="Мої курси"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox x:Name="CoursesList"
                             Height="360"
                             FontSize="15"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Padding="8"
                             DisplayMemberPath="Title"
                             SelectionChanged="CoursesList_SelectionChanged"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="12,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Інформація про курс"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Назва:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Опис:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DescText"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Викладач:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TeacherText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Матеріали:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        
                        <ListBox x:Name="MaterialsList"
                                 FontSize="15"
                                 Height="110"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,5,0,15"
                                 MouseDoubleClick="MaterialsList_DoubleClick"/>

                        <TextBlock Text="Завдання:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>

                        <ListBox x:Name="AssignmentsList"
                                 FontSize="15"
                                 Height="110"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,5,0,0"
                                 MouseDoubleClick="AssignmentsList_DoubleClick"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>