<Window x:Class="DistLearn.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Segoe UI">

    <Grid>
        <Border Width="600"
                Height="500"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Вхід у систему"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Text="Логін"
                           FontSize="18"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" Margin="44,30,0,10" Grid.RowSpan="3"/>
                
                <Border Grid.Row="4"
                        Background="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="450">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBox x:Name="LoginBox"
                             Height="40"
                             Width="450"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="15"/>
                </Border>

                <TextBlock Grid.Row="6"
                           Text="Пароль"
                           FontSize="18"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" Margin="44,0,0,0"/>

                <Border Grid.Row="8"
                        Background="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="450">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <PasswordBox x:Name="PassBox"
                                 Height="40"
                                 Width="450"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="15"/>
                    
                </Border>

                <StackPanel Grid.Row="10"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="CancelBtn"
                            Content="Скасувати"
                            Width="120"
                            Height="40"
                            Margin="0,0,12,0"
                            Background="#111827"
                            Foreground="White"
                            BorderBrush="#374151"
                            Click="CancelBtn_Click"/>

                    <Button x:Name="EnterBtn"
                            Content="Увійти"
                            Width="120"
                            Height="40"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"
                            Click="EnterBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>