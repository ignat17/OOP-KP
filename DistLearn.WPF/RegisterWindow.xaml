<Window x:Class="DistLearn.WPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реєстрація"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid>
        <Border Width="600"
                Height="550"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Реєстрація"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Text="Логін"
                           FontSize="16"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" Margin="44,30,44,8" Grid.RowSpan="3"/>

                <Border Grid.Row="4"
                        Width="450"
                        Background="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8">
                    
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBox x:Name="LoginBox"
                             Height="40"
                             Width="450"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="15"/>
                </Border>

                <TextBlock Grid.Row="5"
                           FontSize="16"
                           Text="Пароль"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" 
                           Margin="44,20,44,8" 
                           Grid.RowSpan="3"/>

                <Border Grid.Row="8"
                        Width="450"
                        Background="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8">
                    
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <PasswordBox x:Name="PassBox"
                                 Height="40"
                                 Width="450"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="15"/>
                </Border>

                <TextBlock Grid.Row="9"
                           Text="ПІБ"
                           FontSize="16"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" 
                           Margin="44,20,44,0" 
                           Grid.RowSpan="2"/>

                <Border Grid.Row="12"
                        Width="450"
                        Background="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8">
                    
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <TextBox x:Name="NameBox"
                             Height="40"
                             Width="450"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="15"/>
                </Border>

                <TextBlock Grid.Row="13"
                           Text="Роль"
                           FontSize="16"
                           Foreground="#CBD5E1"
                           FontWeight="Bold" 
                           Margin="44,20,44,0" 
                           Grid.RowSpan="2"/>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Grid.Row="16" Margin="45,0,0,0">
                        <RadioButton x:Name="StudentRadio"
                                     Content="Student"
                                     Foreground="White"
                                     Margin="0,0,30,0"
                                     IsChecked="True"/>

                        <RadioButton x:Name="TeacherRadio"
                                     Content="Teacher"
                                     Foreground="White"
                                     Margin="0,3,30,0"/>
                </StackPanel>


                <StackPanel Grid.Row="18" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="CancelBtn"
                            Content="Скасувати"
                            Width="120"
                            Height="40"
                            Margin="0,0,12,0"
                            Background="#111827"
                            Foreground="White"
                            BorderBrush="#374151"
                            Click="CancelBtn_Click"/>

                    <Button x:Name="SaveBtn"
                            Content="Зареєструватися"
                            Width="150"
                            Height="40"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"
                            Click="SaveBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>