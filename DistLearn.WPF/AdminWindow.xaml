<Window x:Class="DistLearn.WPF.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель адміністратора"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="Панель адміністратора"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock x:Name="UserText"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <Button x:Name="ExitBtn"
                        Content="Вийти"
                        Width="100"
                        Height="38"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#374151"
                        Click="ExitBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,0,12,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Користувачі"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <ListBox x:Name="UsersList"
                                 FontSize="15"
                                 Height="170"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Padding="8"/>

                        <Button x:Name="DeleteUserBtn"
                                Content="Видалити користувача"
                                Width="170"
                                Height="38"
                                Margin="0,10,0,18"
                                HorizontalAlignment="Left"
                                Background="#111827"
                                Foreground="White"
                                BorderBrush="#374151"
                                Click="DeleteUserBtn_Click"/>

                        <TextBlock Text="Логін"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>

                        <Border Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,6,0,12">
                            <TextBox x:Name="LoginBox"
                                     Height="38"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>

                        <TextBlock Text="Пароль"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>

                        <Border Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,6,0,12">
                            <PasswordBox x:Name="PassBox"
                                         Height="38"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="10"/>
                        </Border>

                        <TextBlock Text="ПІБ"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>

                        <Border Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,6,0,12">
                            <TextBox x:Name="NameBox"
                                     Height="38"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>

                        <TextBlock Text="Роль"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>

                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,14">
                            <RadioButton x:Name="StudentRadio"
                                         Content="Student"
                                         Foreground="White"
                                         Margin="0,0,0,8"
                                         IsChecked="True"/>

                            <RadioButton x:Name="TeacherRadio"
                                         Content="Teacher"
                                         Foreground="White"
                                         Margin="0,0,0,8"/>

                            <RadioButton x:Name="AdminRadio"
                                         Content="Administrator"
                                         Foreground="White"/>
                        </StackPanel>

                        <Button x:Name="AddUserBtn"
                                Content="Додати користувача"
                                Width="170"
                                Height="38"
                                HorizontalAlignment="Left"
                                Background="#2563EB"
                                Foreground="White"
                                BorderBrush="#2563EB"
                                Click="AddUserBtn_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="12,0,0,0">

                <StackPanel>
                    <TextBlock Text="Курси"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox x:Name="CoursesList"
                             FontSize="15"
                             Height="300"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Padding="8"
                             DisplayMemberPath="Title"/>

                    <Button x:Name="DeleteCourseBtn"
                            Content="Видалити курс"
                            Width="140"
                            Height="38"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Background="#111827"
                            Foreground="White"
                            BorderBrush="#374151"
                            Click="DeleteCourseBtn_Click"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SaveJsonBtn"
                                Content="Зберегти JSON"
                                Width="150"
                                Height="38"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Left"
                                Background="#2563EB"
                                Foreground="White"
                                BorderBrush="#2563EB"
                                Click="SaveJsonBtn_Click"/>

                        <Button x:Name="LoadJsonBtn"
                                Content="Завантажити JSON"
                                Width="160"
                                Height="38"
                                HorizontalAlignment="Left"
                                Background="#111827"
                                Foreground="White"
                                BorderBrush="#374151"
                                Click="LoadJsonBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>