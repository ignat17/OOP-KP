<Window x:Class="DistLearn.WPF.AssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завдання"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Завдання"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="SemiBold"/>

        <Grid x:Name="ContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="InfoBorder"
                    Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,12,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Назва:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Опис:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DescText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Інструкції:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="InstructionsText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Максимальний бал:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="ScoreText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Дедлайн:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DeadlineText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,0,0,0">

                    <Border x:Name="StudentBlock"
                            Background="#111827"
                            BorderBrush="#1F2937"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,12">

                        <StackPanel>
                            <TextBlock Text="Здача роботи"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Файл"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       FontWeight="Bold"/>

                            <Border Background="#1E293B"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,6,0,12">
                                <TextBox x:Name="FilePathBox"
                                         Height="38"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="10"/>
                            </Border>

                            <Button x:Name="ChooseFileBtn"
                                    Content="Вибрати файл"
                                    Width="140"
                                    Height="38"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderBrush="#2563EB"
                                    Click="ChooseFileBtn_Click"/>

                            <TextBlock Text="Коментар"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       FontWeight="Bold"/>

                            <Border Background="#1E293B"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,6,0,12">
                                <TextBox x:Name="CommentBox"
                                         Height="90"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="10"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </Border>

                            <TextBlock Text="Статус:"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="StatusText"
                                       Foreground="White"
                                       FontSize="15"
                                       Margin="0,5,0,12"/>

                            <Button x:Name="SubmitBtn"
                                    Content="Здати роботу"
                                    Width="140"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderBrush="#2563EB"
                                    Click="SubmitBtn_Click"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="TeacherBlock"
                            Background="#111827"
                            BorderBrush="#1F2937"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20">

                        <StackPanel>
                            <TextBlock Text="Здані роботи"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <ListBox x:Name="SubmissionsList"
                                     Height="180"
                                     Background="#1E293B"
                                     Foreground="White"
                                     BorderBrush="#334155"
                                     BorderThickness="1"
                                     SelectionChanged="SubmissionsList_SelectionChanged"/>

                            <TextBlock Text="Коментар студента:"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       FontWeight="Bold"
                                       Margin="0,12,0,6"/>
                            <TextBlock x:Name="SubmissionCommentText"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Файл:"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="SubmissionFileText"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,12"/>

                            <Button x:Name="OpenFileBtn"
                                    Content="Відкрити файл"
                                    Width="140"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderBrush="#2563EB"
                                    Click="OpenFileBtn_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Button x:Name="CloseBtn"
                Grid.Row="4"
                Content="Закрити"
                Width="120"
                Height="40"
                HorizontalAlignment="Right"
                Background="#2563EB"
                Foreground="White"
                BorderBrush="#2563EB"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>