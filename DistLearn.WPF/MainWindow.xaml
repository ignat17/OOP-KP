<Window x:Class="DistLearn.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DistLearn"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="Платформа дистанційного навчання"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <Button x:Name="RegBtn"
                    Content="Реєстрація"
                    Width="130"
                    Height="38"
                    Margin="10,0,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    BorderBrush="#2563EB"
                    FontSize="13"
                    Click="RegBtn_Click"
                    DockPanel.Dock="Right"/>

            <Button x:Name="LoginBtn"
                    Content="Увійти"
                    Width="100"
                    Height="38"
                    Background="#111827"
                    Foreground="White"
                    BorderBrush="#374151"
                    Click="LoginBtn_Click"
                    FontSize="13"
                    DockPanel.Dock="Right"/>
        </DockPanel>
        
        

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Курси"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox x:Name="CoursesList"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="CoursesList_SelectionChanged">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                SnapsToDevicePixels="True">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Card"
                                        Background="#172033"
                                        BorderBrush="#243049"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="38"
                                                Height="38"
                                                CornerRadius="8"
                                                Background="#2563EB"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="16"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding Teacher.FullName}"
                                                       Foreground="#CBD5E1"
                                                       FontSize="13"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding Enrollments.Count, StringFormat={}{0} студентів}"
                                                       Foreground="#94A3B8"
                                                       FontSize="13"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="Card" Property="Background" Value="#1E293B"/>
                                        <Setter TargetName="Card" Property="BorderBrush" Value="#334155"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="Card" Property="Background" Value="#22304A"/>
                                        <Setter TargetName="Card" Property="BorderBrush" Value="#3B4E6B"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="12,0,0,0">

                <DockPanel LastChildFill="True">
                    <Button x:Name="OpenBtn"
                            Content="Відкрити курс"
                            Width="150"
                            Height="40"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"
                            Click="OpenBtn_Click"
                            DockPanel.Dock="Bottom"
                            HorizontalAlignment="Right"
                            FontSize="13"
                            Margin="0,20,0,0"/>

                    <StackPanel>
                        <TextBlock Text="Інформація про курс"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Назва:"
                                   Foreground="#CBD5E1"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Опис:"
                                   Foreground="#CBD5E1"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DescText"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Викладач:"
                                   Foreground="#CBD5E1"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TeacherText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Кількість студентів:"
                                   Foreground="#CBD5E1"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="CountText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>