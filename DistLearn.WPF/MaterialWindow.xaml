<Window x:Class="DistLearn.WPF.MaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Матеріал"
        Height="500"
        Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Матеріал"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="2"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="10"     
                Padding="20">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Назва:"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="TitleText"
                               Foreground="White"
                               FontSize="15"
                               Margin="0,5,0,15"/>

                    <TextBlock Text="Опис:"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="DescText"
                               Foreground="White"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Margin="0,5,0,15"/>

                    <TextBlock Text="Тип матеріалу:"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="TypeText"
                               Foreground="White"
                               FontSize="15"
                               Margin="0,5,0,15"/>

                    <TextBlock Text="Посилання:"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="UrlText"
                               Foreground="White"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Margin="0,5,0,15"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button x:Name="CloseBtn"
                Grid.Row="4"
                Content="Закрити"
                Width="120"
                Height="40"
                HorizontalAlignment="Right"
                Background="#2563EB"
                Foreground="White"
                BorderBrush="#2563EB"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>