<Window x:Class="DistLearn.WPF.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кабінет викладача"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="Кабінет викладача"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock x:Name="UserText"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <Button x:Name="ExitBtn"
                        Content="Вийти"
                        Width="100"
                        Height="38"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#374151"
                        Click="ExitBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,0,12,0">

                <StackPanel>
                    <TextBlock Text="Мої курси"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox x:Name="CoursesList"
                             FontSize="15"
                             Height="200"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Padding="8"
                             DisplayMemberPath="Title"
                             SelectionChanged="CourseChanged"/>

                    <TextBlock Text="Нова назва курсу"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"
                               Margin="0,18,0,6"/>

                    <Border Background="#1E293B"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#334155"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#60A5FA"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox x:Name="CourseTitleBox"
                                 Height="38"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"/>
                    </Border>

                    <TextBlock Text="Опис курсу"
                               FontSize="15"
                               Foreground="#CBD5E1"
                               FontWeight="Bold"
                               Margin="0,14,0,6"/>

                    <Border Background="#1E293B"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#334155"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#60A5FA"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox x:Name="CourseDescBox"
                                 Height="70"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </Border>

                    <Button x:Name="CreateCourseBtn"
                            Content="Створити курс"
                            Width="140"
                            Height="38"
                            Margin="0,16,0,0"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"
                            Click="CreateCourseBtn_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="12,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Курс"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Назва:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Опис:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DescText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Кількість студентів:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="StudentsText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Матеріали:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <ListBox x:Name="MaterialsList"
                                 FontSize="15"
                                 Height="100"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Завдання:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <ListBox x:Name="AssignmentsList"
                                 FontSize="15"
                                 Height="100"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Назва матеріалу"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>

                        <Border Background="#1E293B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,6,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#60A5FA"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="MaterialTitleBox"
                                     Height="38"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>

                        <Button x:Name="AddMaterialBtn"
                                HorizontalAlignment="Left"
                                Content="Додати матеріал"
                                Width="150"
                                Height="38"
                                Background="#2563EB"
                                Foreground="White"
                                BorderBrush="#2563EB"
                                Click="AddMaterialBtn_Click"/>

                        <Button x:Name="DeleteMaterialBtn"
                                Content="Видалити матеріал"
                                Width="150"
                                Height="38"
                                Margin="20,-38,60,0"
                                Background="#111827"
                                Foreground="White"
                                BorderBrush="#374151"
                                Click="DeleteMaterialBtn_Click"/>

                        <TextBlock Text="Назва завдання"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"
                                   Margin="0,18,0,0"/>

                        <Border Background="#1E293B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,6,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#60A5FA"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="AssignmentTitleBox"
                                     Height="38"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>

                        <TextBlock Text="Дедлайн"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>

                        <DatePicker x:Name="DeadlinePicker"
                                    Height="25"
                                    Width="250"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,12"
                                    Background="White"
                                    Foreground="Black"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AddAssignmentBtn"
                                    Content="Додати завдання"
                                    Width="150"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderBrush="#2563EB"
                                    Click="AddAssignmentBtn_Click"/>

                            <Button x:Name="DeleteAssignmentBtn"
                                    Content="Видалити завдання"
                                    Width="150"
                                    Height="38"
                                    Margin="-5,1,0,0"
                                    Background="#111827"
                                    Foreground="White"
                                    BorderBrush="#374151"
                                    Click="DeleteAssignmentBtn_Click"/>

                            <Button x:Name="DeleteBtn"
                                    Content="Видалити курс"
                                    Width="140"
                                    Height="38"
                                    Margin="6,1,0,0"
                                    Background="#111827"
                                    Foreground="White"
                                    BorderBrush="#374151"
                                    Click="DeleteBtn_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>