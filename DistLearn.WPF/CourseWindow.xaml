<Window x:Class="DistLearn.WPF.CourseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курс"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Tahoma">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Сторінка курсу"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="SemiBold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,12,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Назва:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="20"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Опис:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DescText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Викладач:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TeacherText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Кількість студентів:"
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="StudentsText"
                                   Foreground="White"
                                   FontSize="15"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="12,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Матеріали"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <ListBox x:Name="MaterialsList"
                                 FontSize="15"
                                 Height="150"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,0,0,20"
                                 MouseDoubleClick="MaterialsList_DoubleClick"/>

                        <TextBlock Text="Завдання"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <ListBox x:Name="AssignmentsList"
                                 FontSize="15"
                                 Height="150"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 MouseDoubleClick="AssignmentsList_DoubleClick"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Button x:Name="CloseBtn"
                Grid.Row="4"
                Content="Закрити"
                Width="120"
                Height="40"
                HorizontalAlignment="Right"
                Background="#2563EB"
                Foreground="White"
                BorderBrush="#2563EB"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>